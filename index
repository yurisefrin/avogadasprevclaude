  <!-- =========================
       EVENTOS (WhatsApp click)
       - Meta: Lead + Contact
       - GA4: generate_lead + custom event
       - Google Ads: conversion (opcional)
       ========================= -->
  <script>
    // CONFIG
    const WHATSAPP_NUMBER = "SEU_NUMERO_WHATSAPP"; // ex: 5545999999999

    // Se usar Google Ads conversão por clique no WhatsApp:
    const USE_GOOGLE_ADS_CONVERSION = false; // mude para true se configurar abaixo
    const AW_SEND_TO = "AW_CONVERSION_ID/AW_CONVERSION_LABEL"; // ex: "AW-123456789/AbCDeFGhijkLmNoP"

    function trackWhatsAppClick(extra = {}) {
      try {
        if (window.fbq) {
          fbq('track', 'Lead');
          fbq('track', 'Contact');
        }
      } catch (e) {}

      try {
        if (window.gtag) {
          gtag('event', 'generate_lead', {
            method: 'whatsapp',
            ...extra
          });
          gtag('event', 'whatsapp_click', {
            method: 'whatsapp',
            ...extra
          });

          if (USE_GOOGLE_ADS_CONVERSION) {
            gtag('event', 'conversion', { 'send_to': AW_SEND_TO });
          }
        }
      } catch (e) {}
    }

    function openWhatsApp(message, extra = {}) {
      trackWhatsAppClick(extra);
      const url = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
      window.open(url, "_blank", "noopener,noreferrer");
    }

    document.addEventListener("DOMContentLoaded", () => {
      // Intercepta cliques em qualquer elemento com data-wa-message
      document.querySelectorAll("[data-wa-message]").forEach((el) => {
        el.addEventListener("click", (ev) => {
          ev.preventDefault();
          const msg = el.getAttribute("data-wa-message") || "Olá! Gostaria de orientação.";
          const ctx = el.getAttribute("data-wa-context") || "unknown";
          openWhatsApp(msg, { context: ctx });
        });
      });
    });
