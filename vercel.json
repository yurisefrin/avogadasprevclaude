{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html$",
      "headers": [
        { "key": "Content-Type", "value": "text/html; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)\\.svg$",
      "headers": [
        { "key": "Content-Type", "value": "image/svg+xml; charset=utf-8" }
      ]
    }
  ]
}
